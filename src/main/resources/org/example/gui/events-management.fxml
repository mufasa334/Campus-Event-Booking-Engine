<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <VBox alignment="TOP_CENTER" layoutY="71.0" minHeight="0.0" minWidth="0.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
         <children>
             <HBox prefHeight="100.0" prefWidth="200.0" spacing="10.0">
                 <children>
                     <TextField fx:id="eventIdField" promptText="Event ID" />
                     <TextField fx:id="eventTitleField" promptText="Title" />
                     <TextField promptText="Location (TBD)" />
                     <TextField fx:id="eventCapacityField" promptText="Capacity (Numbers Only)" />
                     <TextField promptText="Date/Time" />
                     <TextField fx:id="specificAttributeField" promptText="Topic/Speaker/Age" />
                     <ComboBox fx:id="eventTypeDropdown" promptText="Event-Type" />

                     <Button onAction="#AddEvent" mnemonicParsing="false" prefHeight="25.0" text="Add Event" />
                 </children>
             </HBox>
             <TableView fx:id="eventTable" prefHeight="150.0" prefWidth="336.0" VBox.vgrow="ALWAYS">
                 <columns>
                     <TableColumn fx:id="colEventId" prefWidth="75.0" text="Event ID" />
                     <TableColumn fx:id="colEventTitle" prefWidth="100.0" text="Title" />
                     <TableColumn fx:id="colEventCapacity" prefWidth="75.0" text="Capacity" />
                     <TableColumn fx:id="colEventType" prefWidth="75.0" text="Type" />
                     <TableColumn fx:id="colEventStatus" prefWidth="75.0" text="Status" />
                 </columns>
                 <columnResizePolicy>
                     <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                 </columnResizePolicy>
             </TableView>
         </children>
      </VBox>
   </children>
</AnchorPane>
