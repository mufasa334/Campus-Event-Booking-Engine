<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.gui.HelloController">
   <children>
      <VBox alignment="TOP_CENTER" layoutY="71.0" minHeight="0.0" minWidth="0.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
         <children>
            <HBox prefHeight="100.0" prefWidth="200.0" spacing="10.0">
               <children>
                  <TextField fx:id="idField" promptText="Event ID" />
                  <TextField fx:id="nameField" promptText="Title" />
                  <TextField fx:id="emailField" promptText="Location" />
                  <TextField fx:id="idField1" promptText="Capacity" />
                  <TextField fx:id="idField11" promptText="Date/Time" />
                  <TextField fx:id="idField111" promptText="Topic/Speaker/Age" />
                  <ComboBox fx:id="roleComboBox" prefWidth="150.0" promptText="Event Type" />
                  <Button fx:id="addUser" mnemonicParsing="false" prefHeight="25.0" prefWidth="37.0" text="Add-User" />
               </children>
            </HBox>
            <TableView fx:id="userTable" prefHeight="150.0" prefWidth="336.0" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn prefWidth="75.0" text="ID" />
                <TableColumn prefWidth="75.0" text="Title" />
                  <TableColumn prefWidth="75.0" text="Date/Time" />
                  <TableColumn prefWidth="75.0" text="Location" />
                  <TableColumn prefWidth="75.0" text="Capacity" />
                  <TableColumn prefWidth="75.0" text="Status" />
                  <TableColumn prefWidth="75.0" text="Type" />
                  <TableColumn prefWidth="75.0" text="Topic" />
                  <TableColumn prefWidth="75.0" text="Speaker" />
                  <TableColumn prefWidth="75.0" text="AgeRestriction" />
              </columns>
            </TableView>
         </children>
      </VBox>
   </children>
</AnchorPane>
