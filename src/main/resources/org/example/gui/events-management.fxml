<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <VBox alignment="TOP_CENTER" layoutY="71.0" minHeight="0.0" minWidth="0.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
         <children>
             <HBox prefHeight="40.0" prefWidth="200.0" spacing="10.0">
                 <children>
                     <TextField fx:id="eventIdField" prefWidth="70.0" promptText="Event ID" />
                     <TextField fx:id="eventTitleField" prefWidth="80.0" promptText="Title" />
                     <TextField prefWidth="80.0" promptText="Location" />
                     <TextField fx:id="eventCapacityField" prefWidth="80.0" promptText="Capacity" />
                     <TextField fx:id="eventDateTimeField" prefWidth="80.0" promptText="yyyy-MM-ddTHH:mm" />
                     <TextField fx:id="specificAttributeField" prefWidth="110.0" promptText="Topic/Speaker/Age" />
                     <ComboBox fx:id="eventTypeDropdown" prefWidth="110.0" promptText="Event-Type" />
                     <Button onAction="#AddEvent" mnemonicParsing="false" prefHeight="25.0" prefWidth="100.0" text="Add Event" />
                 </children>
             </HBox>
             <HBox prefHeight="40.0" prefWidth="200.0" spacing="10.0">
                 <children>
                     <ComboBox fx:id="waitlistEventSelection" prefWidth="200.0" promptText="Select Event to Cancel" />
                     <Button mnemonicParsing="false" onAction="#handleCancelEvent" prefHeight="25.0" prefWidth="120.0" text="Cancel Event" />
                 </children>
             </HBox>
             <HBox prefHeight="40.0" prefWidth="200.0" spacing="10.0">
                 <children>
                     <TextField fx:id="eventSearchField" prefWidth="200.0" promptText="Search by title..." />
                     <ComboBox fx:id="eventTypeFilter" prefWidth="130.0" promptText="Filter by Type" />
                     <Button mnemonicParsing="false" onAction="#handleSearchEvents" prefHeight="25.0" prefWidth="80.0" text="Search" />
                     <Button mnemonicParsing="false" onAction="#handleClearSearch" prefHeight="25.0" prefWidth="80.0" text="Clear" />
                 </children>
             </HBox>
             <TableView fx:id="eventTable" prefHeight="150.0" prefWidth="336.0" VBox.vgrow="ALWAYS">
                 <columns>
                     <TableColumn fx:id="colEventId" prefWidth="75.0" text="Event ID" />
                     <TableColumn fx:id="colEventTitle" prefWidth="100.0" text="Title" />
                     <TableColumn fx:id="colEventCapacity" prefWidth="75.0" text="Capacity" />
                     <TableColumn fx:id="colEventType" prefWidth="75.0" text="Type" />
                     <TableColumn fx:id="colEventStatus" prefWidth="75.0" text="Status" />
                     <TableColumn fx:id="colEventDateTime" prefWidth="130.0" text="Date/Time" />
                 </columns>
                 <columnResizePolicy>
                     <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                 </columnResizePolicy>
             </TableView>
         </children>
      </VBox>
   </children>
</AnchorPane>
