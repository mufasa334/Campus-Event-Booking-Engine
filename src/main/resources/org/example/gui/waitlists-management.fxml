<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <VBox alignment="TOP_CENTER"
              AnchorPane.topAnchor="10.0"
              AnchorPane.bottomAnchor="10.0"
              AnchorPane.leftAnchor="10.0"
              AnchorPane.rightAnchor="10.0"
              spacing="12.0">

            <padding>
                <Insets top="20.0" right="20.0" bottom="20.0" left="20.0" />
            </padding>

            <children>

                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <children>
                        <ComboBox fx:id="waitlistEventSelection"
                                  prefWidth="220.0"
                                  promptText="Select Event" />

                        <Button text="View Waitlist"
                                mnemonicParsing="false"
                                onAction="#handleViewWaitlist"
                                prefWidth="120.0" />
                    </children>
                </HBox>

                <TableView fx:id="waitlistTable"
                           prefHeight="220.0"
                           VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colWaitUser"
                                     text="User" />
                        <TableColumn fx:id="colWaitStatus"
                                     text="Status" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <TextArea fx:id="notificationArea"
                          editable="false"
                          wrapText="true"
                          prefHeight="160.0"
                          text="System Notifications will appear here..."
                          VBox.vgrow="ALWAYS" />

            </children>
        </VBox>
    </children>
</AnchorPane>